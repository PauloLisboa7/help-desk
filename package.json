{
  "name": "help-desk-corporativo",
  "version": "3.0.0",
  "description": "Sistema Help Desk Corporativo para gerenciamento de chamados técnicos",
  "main": "backend/src/app.js",
  "type": "module",
  "scripts": {
    "start": "node backend/src/app.js",
    "dev": "nodemon backend/src/app-dev.js",
    "dev:test": "NODE_ENV=development node backend/src/app-dev.js",
    "migrate": "node backend/src/config/database.js",
    "seed": "node backend/src/seed.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint backend/src --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "backup": "node database/backup.js"
  },
  "keywords": [
    "help-desk",
    "chamados",
    "suporte-técnico",
    "TI"
  ],
  "author": "Técnico em Desenvolvimento de Sistemas",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.11.0",
    "sequelize": "^6.34.0"
  },
  "optionalDependencies": {
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
