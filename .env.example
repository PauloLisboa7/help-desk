# Configurações do Servidor
NODE_ENV=development
PORT=3000
HOST=localhost

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=helpdesk
DB_PASSWORD=helpdesk_password
DB_NAME=helpdesk_db

# JWT
JWT_SECRET=sua_chave_jwt_super_secreta_aqui
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=sua_chave_refresh_secreta_aqui

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app
EMAIL_FROM=noreply@helpdesk.com

# Google Cloud Vertex AI
GOOGLE_CLOUD_PROJECT_ID=help-desk-498913
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_MODEL=chat-bison
GOOGLE_CLOUD_API_KEY=SEU_GOOGLE_CLOUD_API_KEY_AQUI

# Segurança
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=seu_session_secret_aqui

# Arquivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# SLA Padrão (em horas)
SLA_CRITICAL=4
SLA_HIGH=8
SLA_MEDIUM=24
SLA_LOW=72

# Logs
LOG_LEVEL=debug
LOG_DIR=./logs

# Docker
DOCKER_ENV=false
